# swaylock-effects https://github.com/jirutka/swaylock-effects/

indicator
#indicator-caps-lock
ignore-empty-password
indicator-radius=90
#grace=5
#grace-no-mouse

#fade-in=0.5
effect-blur=7x7
image=$HOME/Pictures/Wallpaperz/wallhaven-wqqke6.jpg
scaling=fill

font=Rubik
font-size=20

clock
timestr=%H:%M.%S
datestr=%x

ring-color=#d65d0e75
line-color=#00000000
inside-color=#32323275
text-color=#ebdbb2

key-hl-color=#98971acc
bs-hl-color=#ebdbb275
caps-lock-key-hl-color=#689d6a
caps-lock-bs-hl-color=#ebdbb2

ring-ver-color=#45858875
