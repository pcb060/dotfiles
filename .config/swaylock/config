inside-ver-color=#32323275
text-ver-color=#ebdbb2

ring-clear-color=#ebdbb275
line-clear-color=#00000000
inside-clear-color=#32323275
text-clear-color=#ebdbb2


ring-caps-lock-color=#83a598
line-caps-lock-color=#00000000
inside-caps-lock-color=#32323275
text-caps-lock-color=#ebdbb2

ring-wrong-color=#ff000075
