# Apply gtk theming
exec_always ~/.config/sway/scripts/import-gsettings

# Default Font
font pango:Rubik 11

# set $bg 	        #d65d0e
set $bg             #b8bb26
set $bg-dark        #98971a
set $bg-inactive    #32302f
set $bg-urgent      #000000
set $text           #ebdbb2
set $text-inactive  #bdae93

set $bar            #323232
set $statusline     #e0e0e0

# class                 border        background   text           indicator child_border
client.focused          $bg-dark      $bg-dark     $bg-urgent     $bg       $bg
client.unfocused        $bg-inactive  $bg-inactive $text-inactive $bar      $bar
client.focused_inactive $bg-inactive  $bg-inactive $text-inactive $bar      $bar
client.urgent           $bg-urgent    $bg-urgent   $text          $bar      $bar

## Hide titlebar on windows:
#default_border pixel 1
default_border pixel 4
default_floating_border pixel 4

# centers titles
title_align center

# hides borders when tabbed/stacked
hide_edge_borders smart

# Set inner/outer gaps
gaps outer 5
gaps inner 5

# Thin borders:
smart_borders on

# # Set wallpaper:
# exec swaybg -i ~/.config/sway/sway.png

# Title format for windows
for_window [shell="xdg_shell"] title_format "%title (%app_id)"
for_window [shell="x_wayland"] title_format "%class - %title"

# Status Bar:
# Read `man 5 sway-bar` for more information about this section.
bar {
    swaybar_command waybar
}
